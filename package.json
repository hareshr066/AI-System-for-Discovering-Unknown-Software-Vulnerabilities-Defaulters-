{
  "name": "ai-vulnerability-scanner",
  "version": "1.0.0",
  "description": "Full-stack AI Vulnerability Scanner",
  "scripts": {
    "start:frontend": "npm run dev --prefix frontend",
    "start:backend": "cd backend && .\\venv\\Scripts\\python.exe -m uvicorn main:app --reload --port 8000",
